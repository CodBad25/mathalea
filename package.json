  "scripts": {
    "dev": "pnpm makeJson && vite",
    "start": "pnpm makeJson && vite",
    "buildRam": "pnpm makeJson && pnpm doc && node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "build": "pnpm makeJson && vite build",
    "build:deploy": "pnpm build && pnpm doc && tasks/deploy_site.sh && open https://coopmaths.fr/alea",
    "deploy:site": "tasks/deploy_site.sh && open https://coopmaths.fr/alea",
    "makeJson": "node tasks/dictionnaireToReferentiel.js && node tasks/updateMenuInternational",
    "getNewUuid": "pnpm makeJson",
    "updateMenu": "pnpm makeJson",
    "updateMenuCH": "pnpm makeJson",
    "preview": "vite preview",
    "check": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec svelte-check --tsconfig ./tsconfig.json",
    "check:lib": "svelte-check --tsconfig ./tsconfig.check-lib.json",
    "check:components": "svelte-check --tsconfig ./tsconfig.check-components.json",
    "count:variants": "node tasks/count-variants.js",
    "transpile": "tsc > journal.log",
    "lint": "eslint --fix 'src/exercices/**/*.{js,ts}'",
    "lintSvelte": "eslint --fix 'src/components/**/*.{js,ts}'",
    "format": "pnpm exec prettier --write src && pnpm exec prettier --write tasks && pnpm exec prettier --write tests",
    "doc": "pnpm exec typedoc",
    "addDNB": "pnpm --package=git+https://forge.apps.education.fr/coopmaths/dnb -c dlx dnbindex",
    "test:unit": "vitest tests/unit --run --exclude .pnpm-store",
    "test:src": "vitest src --run --exclude .pnpm-store",
    "test:coverage": "vitest --run --coverage --exclude .pnpm-store",
    "test:coverage:unit": "vitest tests/unit --run --coverage --exclude .pnpm-store",
    "test:coverage:src": "vitest src --run --coverage --exclude .pnpm-store",
    "test:e2e": "pnpm test:e2e:all",
    "test:e2e:dev": "vitest --config tests/e2e/vitest.config.dev.js --watch",
    "test:e2e:all": "NIV='' vitest --config tests/e2e/vitest.config.all.js --run",
    "test:e2e:interactivity": "vitest --config tests/e2e/vitest.config.interactivity.js --run",
    "test:e2e:pdfexports": "vitest --config tests/e2e/vitest.config.pdfexports.js --run",
    "test:e2e:console_errors": "vitest --config tests/e2e/vitest.config.console_errors.js --run",
    "test:e2e:console_errors:debug": "vitest --config tests/e2e/vitest.config.console_errors.debug.js --run",
    "test:e2e:views": "vitest --config tests/e2e/vitest.config.view.js --run",
    "test:e2e:consistency": "vitest --config tests/e2e/vitest.config.consistency.js --run",
    "screenshot": "vitest --config tests/e2e/vitest.config.screenshot.js --run",
    "testExercice": "vitest --config tests/e2e/vitest.config.new_exercise.js --run",
    "test:interactivity": "vitest --config tests/integration/vitest.config.interactivity_all.js --run",
    "test:interactivity:watch": "vitest --config tests/integration/vitest.config.interactivity_all.js",
    "test:exo:file": "NIV=$FILE pnpm test:e2e:console_errors",
    "test:exo:file:headed": "HEADFUL=1 DEBUG=DEBUG SLOWMO=200 NIV=$FILE pnpm test:e2e:console_errors",
    "test:exo:file:debug": "HEADFUL=1 PAUSE_ON_ERROR=1 DEBUG=DEBUG SLOWMO=200 NIV=$FILE pnpm test:e2e:console_errors:debug",
    "prepare": "husky",
    "update:apigeom-snapshots": "node tasks/update-apigeom-snapshots.js",
    "prebuild-unit-tests": "pnpm test:unit && pnpm test:src",
    "prebuild-e2e-tests": "AUTOTEST=true pnpm test:e2e:views && AUTOTEST=true pnpm test:e2e:interactivity && AUTOTEST=true pnpm test:e2e:consistency",
    "test:mr": "pnpm prebuild-unit-tests && pnpm prebuild-e2e-tests"
  },
  "dependencies": {
    "@bugsnag/js": "^8.9.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@cortex-js/compute-engine": "^0.58.0",
    "@mixer/postmessage-rpc": "^1.1.4",
    "@scratch2latex/scratch-core": "git+https://forge.apps.education.fr/coopmaths/scratch-core.git#main",
    "@svgdotjs/svg.js": "^3.2.5",
    "@types/jspreadsheet-ce": "^4.7.9",
    "@types/nunjucks": "^3.2.6",
    "@types/three": "^0.182.0",
    "apigeom": "git+https://forge.apps.education.fr/coopmaths/apigeom.git#v1.4.1",
    "blockly": "12.5.1",
    "boxicons": "^2.1.4",
    "daisyui": "^5.5.19",
    "decimal.js": "^10.6.0",
    "earcut": "^3.0.2",
    "fraction-visualizer": "git+https://forge.apps.education.fr/coopmaths/apps/fraction-visualizer.git",
    "git-precommit-checks": "^3.1.0",
    "glisse-nombre": "git+https://forge.apps.education.fr/coopmaths/apps/glisse-nombre.git",
    "instrumenpoche": "git+https://git.sesamath.net/sesamath/instrumenpoche.git",
    "jspreadsheet-ce": "git+https://forge.apps.education.fr/coopmaths/apps/spreadsheet-ce.git",
    "jszip": "^3.10.1",
    "jszip-utils": "^0.1.0",
    "katex": "^0.16.46",
    "labyrinthe": "git+https://forge.apps.education.fr/coopmaths/apps/labyrinthe.git",
    "mathlive": "^0.109.2",
    "nunjucks": "^3.2.4",
    "qrcode": "^1.5.4",
    "roughjs": "^4.6.6",
    "scratchblocks": "^3.6.4",
    "seedrandom": "^3.0.5",
    "sortablejs": "^1.15.7",
    "three": "^0.182.0",
    "troika-three-text": "^0.52.4",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/earcut": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.8.0",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "playwright": "1.60.0",
    "pnpm": "^10.33.4",
    "postcss": "^8.5.14",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass": "^1.99.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typed-function": "^4.2.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "util": "^0.12.5",
    "vite": "^7.3.3",
    "vite-plugin-dynamic-import": "^1.6.0",
    "vite-plugin-generate-file": "0.3.1",
    "vitest": "^4.1.6"
  },
  "git-precommit-checks": {
    "display": {
      "notifications": true,
      "offendingContent": true,
      "rulesSummary": true,
      "shortStats": true,
      "verbose": true
    },
    "rules": [
      {
        "filter": "\\.js$|\\.ts$",
        "nonBlocking": "true",
        "message": "🤫 Oula, aurais-tu oublié des `console.log` inopportuns ?",
        "regex": "console\\.log"
      },
      {
        "message": "😨 On dirait que tu as oublié des marqueurs de conflits",
        "regex": "/^[<>|=]{4,}/m"
      },
      {
        "message": "🤔 Aurais-tu oublié de finir des développement ?",
        "nonBlocking": "true",
        "regex": "(?:FIXME|TODO)"
      }
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "git-precommit-checks"
    }
  },
  "pnpm": {
    "overrides": {
      "typed-function@<0.10.6": ">=4.0.0",
      "moment@>=2.18.0 <2.29.4": ">=2.29.4",
      "svelte@<3.49.0": ">=3.49.0",
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "apigeom",
      "esbuild",
      "svelte-preprocess",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
